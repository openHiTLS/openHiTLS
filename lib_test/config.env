# libboundcheck.so 的路径
export LIB_BOUNDSCHECK=/usr/local/lib

# libhitls_crypto.a libhitls_bsl.a 的路径
export LIB_HITLS=/usr/local/lib

if [ -z "$LD_LIBRARY_PATH" ]; then
    export LD_LIBRARY_PATH=$LIB_BOUNDSCHECK
else
    export LD_LIBRARY_PATH=$LIB_BOUNDSCHECK:$LD_LIBRARY_PATH
fi

# If you use hitls_xxx.so 
# export LD_LIBRARY_PATH=$LIB_HITLS:$LD_LIBRARY_PATH

# hitls头文件路径，确保你的hitls文件夹中包含bsl/ crypto/ 文件夹
export INC_HITLS_PATH=/usr/local/include/hitls